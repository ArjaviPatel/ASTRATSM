# ============================================================================
# AstraTSM backend environment — copy to `.env` and fill in real values.
#   cp .env.example .env
# Required keys have NO safe default and the app will refuse to start without
# them (SECRET_KEY, ALLOWED_HOSTS, CORS_ALLOWED_ORIGINS, DB_*).
# ============================================================================

# ─── Core ───────────────────────────────────────────────────────────────────
# Generate a fresh one: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Comma-separated hostnames/IPs this backend may serve.
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,127.0.0.1
# Local timezone — makes Celery reminder times (e.g. 17:30) mean LOCAL time.
TIME_ZONE=Asia/Kolkata

# Absolute URLs (used for building links in emails / media)
BACKEND_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# Force HTTPS redirects. Set False only if TLS is terminated elsewhere and you
# are testing over plain HTTP.
SECURE_SSL_REDIRECT=True

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DB_NAME=astratsm
DB_USER=astratsm
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432

# ─── CORS ───────────────────────────────────────────────────────────────────
# Origins allowed to call the API from a browser (the frontend origin).
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ─── Redis / Celery ─────────────────────────────────────────────────────────
# Used for Channels, cache, and the Celery broker/result backend.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# If Redis needs a password: redis://:yourpassword@localhost:6379/1

# Timesheet reminder times (24h, in TIME_ZONE). Defaults: 17:30 and 17:45.
TIMESHEET_REMINDER_1_HOUR=17
TIMESHEET_REMINDER_1_MINUTE=30
TIMESHEET_REMINDER_2_HOUR=17
TIMESHEET_REMINDER_2_MINUTE=45

# ─── Email ──────────────────────────────────────────────────────────────────
# Option A — SMTP (e.g. SendGrid). Leave MS_GRAPH_* blank to use this.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@your-domain.com
ALLOWED_USER_EMAIL_DOMAIN=your-domain.com

# Option B — Microsoft Graph (preferred automatically when all 4 are set).
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER_EMAIL=

# ─── Login OTP ──────────────────────────────────────────────────────────────
LOGIN_OTP_TTL_SECONDS=90
LOGIN_OTP_LENGTH=6

# ─── Media storage (optional S3) ────────────────────────────────────────────
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# ─── Observability (optional) ───────────────────────────────────────────────
SENTRY_DSN=
ENVIRONMENT=production
